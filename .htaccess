RewriteEngine On

# If the requested file/directory doesn't exist in /out, serve fallback pages
RewriteCond %{REQUEST_URI} !^/out/
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI} -f [OR]
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI} -d
RewriteRule ^(.*)$ /out/$1 [L]

# Team member fallback - serve muna-salvi page as shell (client-side routing handles it)
RewriteCond %{REQUEST_URI} ^/team/[^/]+/$
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI}index.html !-f
RewriteRule ^(.*)$ /out/team/muna-salvi/index.html [L]

# Insights fallback - serve first insight page as shell
RewriteCond %{REQUEST_URI} ^/insights/[^/]+/$
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI}index.html !-f
RewriteRule ^(.*)$ /out/insights/four-pressures-redefining-uae-compliance-2026/index.html [L]

# Default fallback to out folder
RewriteCond %{REQUEST_URI} !^/out/
RewriteRule ^(.*)$ /out/$1 [L]
