RewriteEngine On
RewriteBase /

# Don't rewrite if already in /out
RewriteCond %{REQUEST_URI} ^/out/ [NC]
RewriteRule ^ - [L]

# Serve static files from out folder FIRST (images, css, js, fonts, etc.)
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI} -f
RewriteRule ^(.*)$ /out/$1 [L]

# Add trailing slash if missing (except for files with extensions)
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
RewriteRule ^(.*)$ /$1/ [R=301,L]

# If index.html exists in out folder for this path, serve it
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI}index.html -f
RewriteRule ^(.*)$ /out/$1index.html [L]

RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI} -d
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI}index.html -f
RewriteRule ^(.*)$ /out/$1index.html [L]

# Team fallback for unknown slugs
RewriteCond %{REQUEST_URI} ^/team/[^/]+/?$
RewriteRule ^ /out/team/muna-salvi/index.html [L]

# Insights fallback for unknown slugs
RewriteCond %{REQUEST_URI} ^/insights/[^/]+/?$
RewriteRule ^ /out/insights/four-pressures-redefining-uae-compliance-2026/index.html [L]

# Default fallback to 404
RewriteRule ^ /out/404.html [L]
