RewriteEngine On

# Serve existing files/directories from /out
RewriteCond %{DOCUMENT_ROOT}/out/$1 -f
RewriteRule ^(.*)$ /out/$1 [L]

RewriteCond %{DOCUMENT_ROOT}/out/$1/ -d
RewriteCond %{DOCUMENT_ROOT}/out/$1/index.html -f
RewriteRule ^(.*)$ /out/$1/index.html [L]

# Team member fallback - any /team/SLUG/ that doesn't exist serves muna-salvi shell
RewriteRule ^team/[^/]+/?$ /out/team/muna-salvi/index.html [L]

# Insights fallback - any /insights/SLUG/ that doesn't exist serves first insight shell
RewriteRule ^insights/[^/]+/?$ /out/insights/four-pressures-redefining-uae-compliance-2026/index.html [L]

# Everything else fallback to out folder
RewriteRule ^(.*)$ /out/$1 [L]
